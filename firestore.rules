rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function bootstrapAdmin() {
      return signedIn() && email() == 'sheu5777@gmail.com';
    }

    function memberPath(workspaceId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid);
    }

    function invitePath(workspaceId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(email());
    }

    function activeMember(workspaceId) {
      return signedIn()
        && exists(memberPath(workspaceId))
        && get(memberPath(workspaceId)).data.active == true;
    }

    function role(workspaceId) {
      return get(memberPath(workspaceId)).data.role;
    }

    function editor(workspaceId) {
      return activeMember(workspaceId)
        && role(workspaceId) in ['admin', 'director', 'assistant'];
    }

    function admin(workspaceId) {
      return activeMember(workspaceId)
        && role(workspaceId) == 'admin';
    }

    match /workspaces/{workspaceId}/invites/{inviteEmail} {
      allow read: if admin(workspaceId)
        || (signedIn() && email() == inviteEmail);
      allow create, update: if admin(workspaceId);
      allow delete: if admin(workspaceId)
        || (signedIn() && email() == inviteEmail);
    }

    match /workspaces/{workspaceId}/members/{memberId} {
      allow read: if (signedIn() && memberId == request.auth.uid)
        || activeMember(workspaceId);

      allow create: if admin(workspaceId)
        || (
          bootstrapAdmin()
          && memberId == request.auth.uid
          && request.resource.data.email == email()
          && request.resource.data.role == 'admin'
          && request.resource.data.active == true
        )
        || (
          signedIn()
          && memberId == request.auth.uid
          && request.resource.data.email == email()
          && request.resource.data.active == true
          && exists(invitePath(workspaceId))
          && request.resource.data.role == get(invitePath(workspaceId)).data.role
        );

      allow update, delete: if admin(workspaceId);
    }

    match /workspaces/{workspaceId}/people/{docId} {
      allow read: if activeMember(workspaceId);
      allow create, update, delete: if editor(workspaceId);
    }

    match /workspaces/{workspaceId}/cases/{docId} {
      allow read: if activeMember(workspaceId);
      allow create, update, delete: if editor(workspaceId);
    }

    match /workspaces/{workspaceId}/tasks/{docId} {
      allow read: if activeMember(workspaceId);
      allow create, update, delete: if editor(workspaceId);
    }

    match /workspaces/{workspaceId}/auditLogs/{logId} {
      allow read: if admin(workspaceId);
      allow create: if editor(workspaceId)
        && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
